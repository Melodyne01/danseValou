<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <!-- UIkit CSS -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/css/uikit.min.css" />
        <!-- UIkit JS -->
        <script src="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/js/uikit.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/js/uikit-icons.min.js"></script>
        {{ encore_entry_link_tags('uikit') }}
        {{ encore_entry_link_tags('app') }}
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <header>
        <nav class="uk-navbar-container uk-visible@s" style="z-index: 980; padding: 10px 0px">
            <div class="uk-container">
                <div uk-navbar>
                    <div class="uk-navbar-left">
                        <a class="uk-navbar-item uk-logo" href="{{path('app_home')}}" aria-label="Back to Home"><img src="{{ asset('images/logo.png') }}" width="80" alt="Alternate Text" /></a>
                    </div>
                    <div class="uk-navbar-center">
                        <ul class="uk-navbar-nav">
                            <li><a href="{{path('app_schedule')}}">Horaire</a></li>
                            <li><a href="{{path('app_teachers')}}">Professeurs</a></li>
                            <li><a href="{{path('app_gallery')}}">Photos</a></li>
                            <li><a href="{{path('app_events')}}">Evénements à venir</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
        <nav class="uk-navbar-container uk-hidden@s" style="z-index: 980; padding: 10px 0px">
            <div class="uk-container small-nav">
                <div uk-navbar>
                    <div class="uk-navbar-left">
                        <a class="uk-navbar-toggle uk-navbar-toggle-animate" uk-navbar-toggle-icon href="#"></a>
                        <div class="uk-navbar-dropdown">
                            <ul class="uk-nav uk-navbar-dropdown-nav">
                                <li><a href="{{path('app_schedule')}}">Horaire</a></li>
                                <li><a href="{{path('app_teachers')}}">Professeurs</a></li>
                                <li><a href="{{path('app_gallery')}}">Photos</a></li>
                                <li><a href="{{path('app_events')}}">Evénements à venir</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="uk-navbar-center">
                        <a class="uk-navbar-item uk-logo" href="{{path('app_home')}}" aria-label="Back to Home"><img src="{{ asset('images/logo.png') }}" width="80" alt="Alternate Text" /></a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <body class="uk-background-secondary">
         <!--[if lt IE 7]>
            <p class="browsehappy">You are using an <strong>outdated</strong> browser. Please <a href="#">upgrade your browser</a> to improve your experience.</p>
        <![endif]-->
        {% block body %}{% endblock %}
    </body>
    <footer class="uk-position-relative uk-padding-large uk-padding-remove-bottom" style="background-color: var(--bg-primary);">
        <div class="uk-section uk-section-small footer" id="footer" style="background-color: var(--bg-primary); border: none;">
            <div class="uk-container">
                <div class="uk-text-center">
                    <a target="_blank" href="https://www.instagram.com/its.place_net/" uk-icon="instagram" class="uk-margin-small-right" style="color: var(--accent-primary);"></a>
                    <a target="_blank" href="https://www.linkedin.com/company/it-s-place/" uk-icon="linkedin" class="uk-margin-small-right" style="color: var(--accent-primary);"></a>
                    <a target="_blank" href="https://wa.me/32477753577" uk-icon="whatsapp" style="color: var(--accent-primary);"></a>
                    <br>
                    <p class="copyright uk-margin-small-top" style="opacity: 0.8 !important;">&copy;2024 <a href="https://itsplace.net/" class="uk-link-reset" style="text-decoration: underline; color: var(--accent-primary);">IT'S PLACE</a> | Tous droits réservés</p>
                </div>
            </div>
        </div>
    </footer>
</html>
