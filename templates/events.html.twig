{% extends 'base.html.twig' %}

{% block title %}Hello Controller!{% endblock %}
{% block stylesheets %}
    {{ encore_entry_link_tags('events') }}
{% endblock %}

{% block body %}
<div class="uk-section uk-section-large" style="background-color: var(--bg-primary);">
    <div class="uk-container">
        
        <!-- Header -->
        <div class="uk-text-center uk-margin-large-bottom">
             <div class="uk-inline">
                 <div class="tape tape-top-center"></div>
                 <h1 class="font-handwritten" style="background: #fff; padding: 20px 40px; transform: rotate(1deg); box-shadow: 0 4px 15px rgba(0,0,0,0.1); color: var(--accent-primary);">Evénements à venir</h1>
            </div>
        </div>

        <!-- Event 1 -->
        <div class="uk-grid-large uk-flex-middle" uk-grid>
            <div class="uk-width-1-2@s">
                 <div class="polaroid rotate-neg-2">
                     <div class="tape tape-corner-left"></div>
                    <div class="uk-overflow-hidden" style="height: 300px;">
                        <img src="images/img.png" alt="Event 1" style="object-fit: cover; height: 100%; width: 100%;">
                    </div>
                </div>
            </div>
            <div class="uk-width-1-2@s">
                <div class="sticky-note rotate-1" style="background: #fff9c4; padding: 40px;">
                    <h2 class="font-handwritten" style="color: var(--accent-primary);"><span class="uk-margin-small-right" uk-icon="icon: calendar; ratio: 1.5"></span> Aout 2025</h2>
                    <h3 style="margin-top: 10px;">Début des incriptions</h3>
                    <p class="uk-text-meta"><span class="uk-margin-small-right" uk-icon="icon: location; ratio: 1"></span> Salle Principale</p>
                    <p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Maiores cumque omnis quae quasi esse voluptas, aliquam, reprehenderit voluptatem aliquid officia error.</p>
                </div>
            </div>
        </div>

        <!-- Event 2 -->
        <div class="uk-grid-large uk-flex-middle uk-margin-xlarge-top" uk-grid>
            <div class="uk-width-1-2@s uk-flex-last@s">
                 <div class="polaroid rotate-2">
                     <div class="tape tape-corner-right"></div>
                    <div class="uk-overflow-hidden" style="height: 300px;">
                        <img src="images/img.png" alt="Event 2" style="object-fit: cover; height: 100%; width: 100%;">
                    </div>
                </div>
            </div>
            <div class="uk-width-1-2@s">
                 <div class="sticky-note rotate-neg-1 pink" style="padding: 40px;">
                    <h2 class="font-handwritten" style="color: var(--accent-primary);"><span class="uk-margin-small-right" uk-icon="icon: calendar; ratio: 1.5"></span> Septembre 2025</h2>
                    <h3 style="margin-top: 10px;">Reprise des cours</h3>
                    <p class="uk-text-meta"><span class="uk-margin-small-right" uk-icon="icon: location; ratio: 1"></span> Toutes Salles</p>
                    <p>Sed laborum commodi, assumenda iure quo suscipit enim ipsa molestiae asperiores, ullam tenetur repellendus nostrum. Labore, velit deserunt aperiam voluptatem.</p>
                </div>
            </div>
        </div>

        <!-- Event 3 -->
        <div class="uk-grid-large uk-flex-middle uk-margin-xlarge-top" uk-grid>
            <div class="uk-width-1-2@s">
                 <div class="polaroid rotate-neg-1">
                     <div class="tape tape-top-center"></div>
                    <div class="uk-overflow-hidden" style="height: 300px;">
                        <img src="images/img.png" alt="Event 3" style="object-fit: cover; height: 100%; width: 100%;">
                    </div>
                </div>
            </div>
            <div class="uk-width-1-2@s">
                 <div class="sticky-note rotate-2 blue" style="padding: 40px;">
                    <h2 class="font-handwritten" style="color: var(--accent-primary);"><span class="uk-margin-small-right" uk-icon="icon: calendar; ratio: 1.5"></span> Décembre 2025</h2>
                    <h3 style="margin-top: 10px;">Spectacle de Noël</h3>
                    <p class="uk-text-meta"><span class="uk-margin-small-right" uk-icon="icon: location; ratio: 1"></span> Théâtre du Centre</p>
                    <p>Rerum aspernatur, dolorem mollitia vitae officiis atque qui dolor. Maiores cumque omnis quae quasi esse voluptas.</p>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
