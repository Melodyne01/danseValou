{% extends 'base.html.twig' %}

{% block title %}Galerie photos – Spectacles et cours de danse à Waterloo – Danse Valou{% endblock %}
{% block meta_description %}Revivez les plus beaux moments de Danse Valou en photos : spectacles, cours et souvenirs de notre école de danse à Waterloo depuis 1989.{% endblock %}

{% block body %}

{# ── PAGE HEADER ─────────────────────────────────────────── #}
<section style="background: var(--bg-primary); padding: 60px 0 0;">
    <div class="uk-container uk-text-center">
        <div class="reveal">
            <span class="section-chip">Souvenirs</span>
        </div>
        <div class="reveal reveal-delay-1" style="margin: 16px 0 8px; display: inline-block; position: relative;">
            <div class="tape tape-top-center"></div>
            <h1 class="font-handwritten page-title-note rotate-neg-2">Notre galerie</h1>
        </div>
        <p class="reveal reveal-delay-2" style="color: var(--text-secondary); max-width: 480px; margin: 20px auto 0;">
            Des moments de magie capturés pour l'éternité — spectacles, cours et répétitions à <strong>Waterloo</strong> depuis 1989.
        </p>
    </div>
</section>

{# ── GALLERY GRID ────────────────────────────────────────── #}
<section class="uk-section" style="background: var(--bg-primary); padding-bottom: 80px;">
    <div class="uk-container">
        <div class="gallery-grid" uk-lightbox="animation: fade">

            <div class="gallery-item reveal reveal-delay-1">
                <div class="polaroid rotate-1">
                    <div class="tape tape-top-center"></div>
                    <div style="overflow: hidden; height: 240px;">
                        <a href="https://picsum.photos/800/600?random=1" data-caption="Danse Valou – Cours de jazz">
                            <img src="https://picsum.photos/400/300?random=1"
                                 alt="Cours de jazz – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                </div>
            </div>

            <div class="gallery-item reveal reveal-delay-2">
                <div class="polaroid rotate-neg-2">
                    <div class="tape tape-corner-left"></div>
                    <div style="overflow: hidden; height: 320px;">
                        <a href="https://picsum.photos/800/1000?random=2" data-caption="Danse Valou – Répétition">
                            <img src="https://picsum.photos/400/500?random=2"
                                 alt="Répétition chorégraphique – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                </div>
            </div>

            <div class="gallery-item reveal reveal-delay-3">
                <div class="polaroid rotate-2">
                    <div class="tape tape-corner-right"></div>
                    <div style="overflow: hidden; height: 200px;">
                        <a href="https://picsum.photos/800/600?random=3" data-caption="Danse Valou – Cours enfants">
                            <img src="https://picsum.photos/400/300?random=3"
                                 alt="Cours de danse pour enfants – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                </div>
            </div>

            <div class="gallery-item reveal reveal-delay-1">
                <div class="polaroid rotate-neg-1">
                    <div style="overflow: hidden; height: 280px;">
                        <a href="https://picsum.photos/800/800?random=4" data-caption="Spectacle 2023 – Danse Valou">
                            <img src="https://picsum.photos/400/400?random=4"
                                 alt="Spectacle 2023 – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                    <p class="font-handwritten uk-text-center" style="color: var(--text-muted); font-size: 1.2rem; padding: 8px 0 0;">Spectacle 2023</p>
                </div>
            </div>

            <div class="gallery-item reveal reveal-delay-2">
                <div class="polaroid rotate-3">
                    <div class="tape tape-top-center"></div>
                    <div style="overflow: hidden; height: 260px;">
                        <a href="https://picsum.photos/800/700?random=5" data-caption="Danse Valou – Atelier contemporain">
                            <img src="https://picsum.photos/400/350?random=5"
                                 alt="Atelier contemporain – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                </div>
            </div>

            <div class="gallery-item reveal reveal-delay-3">
                <div class="polaroid rotate-neg-3">
                    <div class="tape tape-corner-left"></div>
                    <div style="overflow: hidden; height: 210px;">
                        <a href="https://picsum.photos/800/600?random=6" data-caption="Danse Valou – Hip hop">
                            <img src="https://picsum.photos/400/300?random=6"
                                 alt="Cours hip-hop – Danse Valou"
                                 style="object-fit: cover; height: 100%; width: 100%;">
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{% endblock %}
