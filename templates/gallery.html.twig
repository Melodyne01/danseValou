{% extends 'base.html.twig' %}

{% block title %}Hello Controller!{% endblock %}

{% block body %}
<div class="uk-container uk-margin">
    <div class="uk-child-width-1-2@s uk-child-width-1-3@m" uk-grid="masonry: pack; parallax: 150">
        
        <!-- Gallery Item 1 -->
        <div>
            <div class="polaroid rotate-1 tape-top-center">
                <div class="uk-overflow-hidden" style="height: 250px;">
                    <img src="https://picsum.photos/400/300?random=1" alt="Gallery 1" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
            </div>
        </div>

        <!-- Gallery Item 2 -->
        <div class="uk-margin-large-top">
            <div class="polaroid rotate-neg-2">
                 <div class="tape tape-corner-left"></div>
                <div class="uk-overflow-hidden" style="height: 350px;">
                    <img src="https://picsum.photos/400/500?random=2" alt="Gallery 2" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
            </div>
        </div>

        <!-- Gallery Item 3 -->
        <div>
            <div class="polaroid rotate-2">
                <div class="tape tape-corner-right"></div>
                <div class="uk-overflow-hidden" style="height: 200px;">
                    <img src="https://picsum.photos/400/300?random=3" alt="Gallery 3" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
            </div>
        </div>

        <!-- Gallery Item 4 -->
        <div class="uk-margin-medium-top">
            <div class="polaroid rotate-neg-1">
                <div class="uk-overflow-hidden" style="height: 300px;">
                    <img src="https://picsum.photos/400/400?random=4" alt="Gallery 4" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
                <div class="uk-text-center uk-margin-small-top">
                    <span class="font-handwritten" style="color: var(--text-primary);">Spectacle 2023</span>
                </div>
            </div>
        </div>

        <!-- Gallery Item 5 -->
        <div>
            <div class="polaroid rotate-3 tape-top-center">
                <div class="uk-overflow-hidden" style="height: 280px;">
                    <img src="https://picsum.photos/400/350?random=5" alt="Gallery 5" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
            </div>
        </div>

        <!-- Gallery Item 6 -->
        <div class="uk-margin-top">
             <div class="polaroid rotate-neg-3">
                 <div class="tape tape-corner-left"></div>
                <div class="uk-overflow-hidden" style="height: 220px;">
                    <img src="https://picsum.photos/400/300?random=6" alt="Gallery 6" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
            </div>
        </div>
        
    </div>
</div>
{% endblock %}
