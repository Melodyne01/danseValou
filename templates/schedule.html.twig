{% extends 'base.html.twig' %}

{% block title %}Horaire des cours de danse à Waterloo – Danse Valou{% endblock %}
{% block meta_description %}Horaire complet des cours de danse à Waterloo : jazz, classique, contemporain, hip-hop, yoga, éveil corporel et parascolaire. Mercredi, jeudi et vendredi.{% endblock %}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Horaire des cours de danse à Waterloo – Danse Valou",
    "itemListElement": [
        {"@type": "ListItem", "position": 1,  "name": "Jazz Débutant – Mercredi 14h00"},
        {"@type": "ListItem", "position": 2,  "name": "Classique Moyen – Mercredi 15h00"},
        {"@type": "ListItem", "position": 3,  "name": "Contemporain Avancé – Mercredi 16h00"},
        {"@type": "ListItem", "position": 4,  "name": "Hip Hop Ados – Mercredi 17h00"},
        {"@type": "ListItem", "position": 5,  "name": "Yoga Vinyasa – Mercredi 18h00"},
        {"@type": "ListItem", "position": 6,  "name": "Eveil Corporel (4-5 ans) – Jeudi 17h00"},
        {"@type": "ListItem", "position": 7,  "name": "Initiation Danse (6-8 ans) – Jeudi 18h00"},
        {"@type": "ListItem", "position": 8,  "name": "Barre au sol – Jeudi 19h00"},
        {"@type": "ListItem", "position": 9,  "name": "Atelier Chorégraphique – Jeudi 20h00"},
        {"@type": "ListItem", "position": 10, "name": "Funky Jazz (10-12 ans) – Vendredi 17h30"},
        {"@type": "ListItem", "position": 11, "name": "Ragga Ados – Vendredi 18h30"},
        {"@type": "ListItem", "position": 12, "name": "Modern Jazz Adultes – Vendredi 19h30"},
        {"@type": "ListItem", "position": 13, "name": "Stretching – Vendredi 20h30"}
    ]
}
</script>
{% endblock %}

{% block body %}

{# ── PAGE HEADER ─────────────────────────────────────────── #}
<section style="background: var(--bg-primary); padding: 60px 0 0;">
    <div class="uk-container uk-text-center">
        <div class="reveal">
            <span class="section-chip">Planning</span>
        </div>
        <div class="reveal reveal-delay-1" style="margin: 16px 0 8px; display: inline-block; position: relative;">
            <div class="tape tape-top-center"></div>
            <h1 class="font-handwritten page-title-note rotate-neg-1">Notre horaire</h1>
        </div>
        <p class="reveal reveal-delay-2" style="color: var(--text-secondary); max-width: 500px; margin: 20px auto 0;">
            Mercredi, jeudi et vendredi à <strong>Waterloo</strong> — des cours pour tous les âges et tous les niveaux, de 4 ans à l'âge adulte.
        </p>
    </div>
</section>

{# ── SCHEDULE CARDS ──────────────────────────────────────── #}
<section class="uk-section" style="background: var(--bg-primary);">
    <div class="uk-container">
        <div class="uk-grid-match uk-child-width-1-3@m uk-child-width-1-1" uk-grid>

            {# Wednesday #}
            <div class="reveal reveal-delay-1">
                <div class="polaroid schedule-day-card rotate-1"
                     style="background: #e3f2fd; padding: 0; overflow: hidden;">
                    <div class="tape tape-top-center"></div>
                    <div class="day-header" style="background: rgba(164,22,74,0.06); border-bottom: 1px solid rgba(164,22,74,0.08);">
                        <h2 class="font-handwritten" style="color: var(--accent-primary); font-size: 2rem; margin: 0;">Mercredi</h2>
                    </div>
                    <ul class="class-list" style="padding: 8px 0 16px;">
                        <li><span class="class-time">14h00</span> Jazz Débutant</li>
                        <li><span class="class-time">15h00</span> Classique Moyen</li>
                        <li><span class="class-time">16h00</span> Contemporain Avancé</li>
                        <li><span class="class-time">17h00</span> Hip Hop Ados</li>
                        <li><span class="class-time">18h00</span> Yoga Vinyasa</li>
                    </ul>
                </div>
            </div>

            {# Thursday #}
            <div class="reveal reveal-delay-2">
                <div class="polaroid schedule-day-card rotate-neg-1"
                     style="background: #fff9c4; padding: 0; overflow: hidden;">
                    <div class="tape tape-corner-left"></div>
                    <div class="day-header" style="background: rgba(164,22,74,0.06); border-bottom: 1px solid rgba(164,22,74,0.08);">
                        <h2 class="font-handwritten" style="color: var(--accent-primary); font-size: 2rem; margin: 0;">Jeudi</h2>
                    </div>
                    <ul class="class-list" style="padding: 8px 0 16px;">
                        <li><span class="class-time">17h00</span> Éveil Corporel (4–5 ans)</li>
                        <li><span class="class-time">18h00</span> Initiation Danse (6–8 ans)</li>
                        <li><span class="class-time">19h00</span> Barre au sol</li>
                        <li><span class="class-time">20h00</span> Atelier Chorégraphique</li>
                    </ul>
                </div>
            </div>

            {# Friday #}
            <div class="reveal reveal-delay-3">
                <div class="polaroid schedule-day-card rotate-2"
                     style="background: #ffebee; padding: 0; overflow: hidden;">
                    <div class="tape tape-corner-right"></div>
                    <div class="day-header" style="background: rgba(164,22,74,0.06); border-bottom: 1px solid rgba(164,22,74,0.08);">
                        <h2 class="font-handwritten" style="color: var(--accent-primary); font-size: 2rem; margin: 0;">Vendredi</h2>
                    </div>
                    <ul class="class-list" style="padding: 8px 0 16px;">
                        <li><span class="class-time">17h30</span> Funky Jazz (10–12 ans)</li>
                        <li><span class="class-time">18h30</span> Ragga (Ados)</li>
                        <li><span class="class-time">19h30</span> Modern Jazz (Adultes)</li>
                        <li><span class="class-time">20h30</span> Stretching</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── PARASCOLAIRE ────────────────────────────────────────── #}
<section class="uk-section" style="background: var(--bg-secondary);">
    <div class="uk-container">
        <div class="uk-text-center uk-margin-large-bottom reveal">
            <span class="section-chip">Extrascolaire</span>
            <h2 class="font-handwritten" style="margin: 8px 0 0; font-size: 2.5rem;">Parascolaire</h2>
            <p style="color: var(--text-secondary); margin-top: 8px; max-width: 480px; margin-left: auto; margin-right: auto;">
                Activités après l'école pour les enfants et adolescents de <strong>Waterloo</strong> et du Brabant Wallon.
            </p>
        </div>

        <div class="uk-grid-match uk-child-width-1-3@m uk-child-width-1-1" uk-grid>
            <div class="reveal reveal-delay-1">
                <div class="sticky-note parascolaire-card rotate-neg-2">
                    <div class="tape tape-top-center"></div>
                    <h3 class="font-handwritten" style="font-size: 1.8rem; margin-bottom: 12px;">Mercredi</h3>
                    <p style="color: var(--text-secondary); margin: 0;">Activités récréatives et créatives pour les 6–12 ans.</p>
                </div>
            </div>
            <div class="reveal reveal-delay-2">
                <div class="sticky-note parascolaire-card blue rotate-1">
                    <div class="tape tape-top-center"></div>
                    <h3 class="font-handwritten" style="font-size: 1.8rem; margin-bottom: 12px;">Jeudi</h3>
                    <p style="color: var(--text-secondary); margin: 0;">Aide aux devoirs et jeux de société.</p>
                </div>
            </div>
            <div class="reveal reveal-delay-3">
                <div class="sticky-note parascolaire-card pink rotate-2">
                    <div class="tape tape-top-center"></div>
                    <h3 class="font-handwritten" style="font-size: 1.8rem; margin-bottom: 12px;">Vendredi</h3>
                    <p style="color: var(--text-secondary); margin: 0;">Initiation aux arts du spectacle.</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── NOS SALLES ──────────────────────────────────────────── #}
<section class="uk-section" style="background: var(--bg-primary); padding-bottom: 80px;">
    <div class="uk-container">
        <div class="uk-text-center uk-margin-large-bottom reveal">
            <span class="section-chip">Localisation</span>
            <h2 style="margin: 8px 0 0;">Nos salles à Waterloo</h2>
        </div>

        <div class="uk-child-width-1-2@s uk-child-width-1-4@m uk-grid-match" uk-grid>
            <div class="reveal reveal-delay-1">
                <div class="room-card">
                    <div class="room-number">1</div>
                    <p style="font-weight: 700; margin-bottom: 4px; color: var(--text-primary);">École St. François</p>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Rue des Écoles, 1</p>
                </div>
            </div>
            <div class="reveal reveal-delay-2">
                <div class="room-card">
                    <div class="room-number">2</div>
                    <p style="font-weight: 700; margin-bottom: 4px; color: var(--text-primary);">École du Chenois</p>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Avenue des Tilleuls, 5</p>
                </div>
            </div>
            <div class="reveal reveal-delay-3">
                <div class="room-card">
                    <div class="room-number">3</div>
                    <p style="font-weight: 700; margin-bottom: 4px; color: var(--text-primary);">École de l'Envol</p>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Chemin du Vent, 12</p>
                </div>
            </div>
            <div class="reveal reveal-delay-4">
                <div class="room-card">
                    <div class="room-number">4</div>
                    <p style="font-weight: 700; margin-bottom: 4px; color: var(--text-primary);">Sacré Cœur Clos</p>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Place du Clos, 3</p>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}
