{% extends 'base.html.twig' %}

{% block title %}Horaire des cours de danse à Waterloo – Danse Valou{% endblock %}
{% block meta_description %}Horaire complet des cours de danse à Waterloo : jazz, hip-hop, break, contemporain, parascolaire. Mercredi, jeudi, vendredi. Professeurs : Valou, Vanny, Aurélie, Maxim, Sylvie.{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Horaire des cours de danse – Danse Valou Waterloo",
    "itemListElement": [
        {"@type": "ListItem", "position": 1,  "name": "Jazz I – Mercredi 14h-15h (3-6 ans)"},
        {"@type": "ListItem", "position": 2,  "name": "Jazz II & Hip Hop – Mercredi 15h-16h (6-8 ans)"},
        {"@type": "ListItem", "position": 3,  "name": "Jazz III & Hip Hop – Mercredi 16h-17h (9 ans et +)"},
        {"@type": "ListItem", "position": 4,  "name": "Jazz IV & Hip Hop II – Mercredi 17h-18h (12 ans et +)"},
        {"@type": "ListItem", "position": 5,  "name": "Hip Hop III – Mercredi 18h-19h"},
        {"@type": "ListItem", "position": 6,  "name": "Hip Hop IV – Mercredi 19h-20h"},
        {"@type": "ListItem", "position": 7,  "name": "Jazz adulte – Mercredi 20h30-21h30"},
        {"@type": "ListItem", "position": 8,  "name": "Break – Jeudi 15h30-16h30"},
        {"@type": "ListItem", "position": 9,  "name": "Break – Jeudi 17h-18h"},
        {"@type": "ListItem", "position": 10, "name": "Hip Hop I – Jeudi 18h-19h (6-11 ans)"},
        {"@type": "ListItem", "position": 11, "name": "Jazz – Jeudi 19h-20h (15 ans et +)"},
        {"@type": "ListItem", "position": 12, "name": "Jazz II & III & Hip Hop – Vendredi 16h50-17h50 (6 ans et +)"},
        {"@type": "ListItem", "position": 13, "name": "Jazz IV & Hip Hop I – Vendredi 17h50-18h50 (12 ans et +)"},
        {"@type": "ListItem", "position": 14, "name": "Jazz IV Contempo – Vendredi 18h50-19h50 (12 ans et +)"},
        {"@type": "ListItem", "position": 15, "name": "Jazz V Contempo avancé – Vendredi 20h-21h (17 ans et +)"},
        {"@type": "ListItem", "position": 16, "name": "Jazz VI Contempo avancé – Vendredi 21h-22h"}
    ]
}
</script>
{% endblock %}

