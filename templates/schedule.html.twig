{# ── PAGE HEADER ─────────────────────────────────────────── #}
<section class="sched-hero">
    <div class="uk-container uk-text-center">
        <div class="reveal">
            <span class="section-chip">Planning</span>
        </div>
        <div class="reveal reveal-delay-1" style="margin: 16px 0 0; display: inline-block; position: relative;">
            <div class="tape tape-top-center"></div>
            <h1 class="font-handwritten page-title-note sched-main-title rotate-neg-1">Notre horaire</h1>
        </div>
        <p class="reveal reveal-delay-2 sched-subtitle">
            Mercredi, jeudi et vendredi à <strong>Waterloo</strong> — des cours pour tous les âges et tous les niveaux, de 4 ans à l'âge adulte.
        </p>
    </div>
</section>

