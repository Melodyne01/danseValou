{% extends 'base.html.twig' %}

{% block title %}Professeurs de danse à Waterloo – Danse Valou{% endblock %}
{% block meta_description %}Découvrez l'équipe de professeurs de danse de Danse Valou à Waterloo. Enseignants qualifiés en jazz, classique, contemporain, hip-hop et yoga pour tous les niveaux.{% endblock %}
{% block stylesheets %}{{ encore_entry_link_tags('teachers') }}{% endblock %}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Équipe pédagogique – Danse Valou Waterloo",
    "itemListElement": [{"@type": "ListItem", "position": 1, "item": {"@type": "Person", "name": "Valou", "jobTitle": "Présidente et professeure de danse", "worksFor": {"@type": "DanceSchool", "name": "Danse Valou", "address": {"@type": "PostalAddress", "addressLocality": "Waterloo", "postalCode": "1410", "addressCountry": "BE"}}}}]
}
</script>
{% endblock %}

{% block body %}

{# ── PAGE HEADER ─────────────────────────────────────────── #}
<section style="background: var(--bg-primary); padding: 60px 0 0;">
    <div class="uk-container uk-text-center">
        <div class="reveal">
            <span class="section-chip">L'équipe</span>
        </div>
        <div class="reveal reveal-delay-1" style="margin: 16px 0 8px; display: inline-block; position: relative;">
            <div class="tape tape-top-center"></div>
            <h1 class="font-handwritten page-title-note rotate-1">Nos professeurs</h1>
        </div>
        <p class="reveal reveal-delay-2" style="color: var(--text-secondary); max-width: 500px; margin: 20px auto 0;">
            Une équipe passionnée, qualifiée et dédiée à votre épanouissement artistique à <strong>Waterloo</strong> et dans tout le Brabant Wallon.
        </p>
    </div>
</section>

{# ── TEACHER GRID ────────────────────────────────────────── #}
<section class="uk-section" style="background: var(--bg-primary); padding-bottom: 80px;">
    <div class="uk-container">
        <div class="teachers-grid">

            {# Teacher 1 – Valou #}
            <div class="reveal reveal-delay-1">
                <div class="polaroid rotate-1 teacher-card" style="padding-bottom: 52px;">
                    <div class="tape tape-corner-left"></div>
                    <div class="uk-overflow-hidden" style="height: 320px;">
                        <img src="{{ asset('images/image.png') }}"
                             alt="Valou – Présidente et professeure de danse chez Danse Valou"
                             class="uk-transition-scale-up uk-transition-opaque"
                             style="object-fit: cover; height: 100%; width: 100%;">
                    </div>
                    <div class="teacher-overlay">
                        <span class="teacher-overlay-text">Voir la biographie</span>
                    </div>
                    <div class="uk-text-center uk-padding-small">
                        <h3 class="font-handwritten" style="color: var(--text-primary); margin-bottom: 2px; font-size: 1.6rem;">Valou</h3>
                        <p style="color: var(--accent-primary); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin: 0;">Présidente</p>
                    </div>
                    <a href="#modal-valou" uk-toggle class="uk-position-cover" aria-label="Voir la biographie de Valou"></a>
