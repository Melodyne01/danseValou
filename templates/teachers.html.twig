{% extends 'base.html.twig' %}

{% block title %}Hello Controller!{% endblock %}
{% block stylesheets %}
    {{ encore_entry_link_tags('teachers') }}
{% endblock %}

{% block body %}

<div class="uk-container">
    
    <div class="uk-grid-match uk-child-width-1-2@m uk-child-width-1-1" uk-grid>
        
        <!-- Teacher 1 -->
        <div>
            <div class="polaroid rotate-1 uk-inline-clip uk-transition-toggle" tabindex="0">
                <div class="uk-overflow-hidden" style="height: 300px;">
                    <img src="images/image.png" alt="Valou" class="uk-transition-scale-up uk-transition-opaque" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
                <div class="uk-text-center uk-margin-small-top">
                     <h3 class="font-handwritten" style="color: var(--text-primary); margin-bottom: 0;">Valou</h3>
                     <p class="uk-text-meta uk-margin-remove-top" style="color: var(--accent-primary);">Présidente</p>
                </div>
                <a href="#modal-valou" uk-toggle class="uk-position-cover"></a>
            </div>
        </div>

        <!-- Teacher 2 -->
        <div>
             <div class="polaroid rotate-neg-2 uk-inline-clip uk-transition-toggle" tabindex="0">
                <div class="uk-overflow-hidden" style="height: 300px;">
                    <img src="images/image.png" alt="Teacher 2" class="uk-transition-scale-up uk-transition-opaque" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
                <div class="uk-text-center uk-margin-small-top">
                     <h3 class="font-handwritten" style="color: var(--text-primary); margin-bottom: 0;">Professeur 2</h3>
                     <p class="uk-text-meta uk-margin-remove-top" style="color: var(--accent-primary);">Discipline</p>
                </div>
                <a href="#modal-2" uk-toggle class="uk-position-cover"></a>
            </div>
        </div>
        
        <!-- Teacher 3 -->
        <div>
             <div class="polaroid rotate-2 uk-inline-clip uk-transition-toggle" tabindex="0">
                <div class="uk-overflow-hidden" style="height: 300px;">
                    <img src="images/image.png" alt="Teacher 3" class="uk-transition-scale-up uk-transition-opaque" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
                <div class="uk-text-center uk-margin-small-top">
                     <h3 class="font-handwritten" style="color: var(--text-primary); margin-bottom: 0;">Professeur 3</h3>
                     <p class="uk-text-meta uk-margin-remove-top" style="color: var(--accent-primary);">Discipline</p>
                </div>
                <a href="#modal-3" uk-toggle class="uk-position-cover"></a>
            </div>
        </div>

         <!-- Teacher 4 -->
        <div>
             <div class="polaroid rotate-neg-1 uk-inline-clip uk-transition-toggle" tabindex="0">
                <div class="uk-overflow-hidden" style="height: 300px;">
                    <img src="images/image.png" alt="Teacher 4" class="uk-transition-scale-up uk-transition-opaque" style="object-fit: cover; height: 100%; width: 100%;">
                </div>
                <div class="uk-text-center uk-margin-small-top">
                     <h3 class="font-handwritten" style="color: var(--text-primary); margin-bottom: 0;">Professeur 4</h3>
                     <p class="uk-text-meta uk-margin-remove-top" style="color: var(--accent-primary);">Discipline</p>
                </div>
                <a href="#modal-4" uk-toggle class="uk-position-cover"></a>
            </div>
        </div>

    </div>

    <!-- Modals (Simplified for brevity, would be loop in real app) -->
    <div id="modal-valou" class="uk-modal-full" uk-modal>
        <div class="uk-modal-dialog">
            <button class="uk-modal-close-full uk-close-large" type="button" uk-close></button>
            <div class="uk-grid-collapse uk-child-width-1-2@s uk-flex-middle" uk-grid>
                <div class="uk-background-cover" style="background-image: url('images/image.png');" uk-height-viewport></div>
                <div class="uk-padding-large">
                    <h1 class="font-handwritten" style="color: var(--accent-primary);">Valou - Présidente</h1>
                    <p>Lorem ipsum dolor sit amet...</p>
                </div>
            </div>
        </div>
    </div>
    <!-- Add other modals similarly -->
</div>
{% endblock %}
